---
// Film HUD: sol kenarda timecode + sahne adı, klaket ve letterbox bantları
---

<div class="hud" aria-hidden="true">
  <p class="hud__tc mono-label"><span id="tc">TC 00:00:00:00</span> — <span id="tcScene">Sahne 01 · Sessizlik</span></p>
</div>

<div class="slate mono-label" id="slate" aria-hidden="true">
  <span class="slate__dot"></span>
  <span id="slateText">Sahne 01 · Sessizlik — İnt. Karanlık</span>
</div>

<div class="letterbox letterbox--top" id="lbTop" aria-hidden="true"></div>
<div class="letterbox letterbox--bot" id="lbBot" aria-hidden="true"></div>

<style>
  .hud {
    position: fixed;
    left: 0.9rem;
    bottom: 1.1rem;
    z-index: 700;
    pointer-events: none;
  }
  .hud__tc {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    color: var(--text-dim);
    opacity: 0.75;
    letter-spacing: 0.18em;
  }

  .slate {
    position: fixed;
    top: 5.2rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 950;
    display: flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.55em 1.1em;
    background: rgba(11, 17, 34, 0.85);
    border: 1px solid var(--line);
    color: var(--steel-300);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
  }
  .slate__dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #e04141;
    box-shadow: 0 0 8px #e04141;
    animation: rec 1.1s steps(2) infinite;
  }
  @keyframes rec { 50% { opacity: 0.25; } }

  .letterbox {
    position: fixed;
    left: 0;
    right: 0;
    height: clamp(34px, 5.5vh, 62px);
    background: #05080f;
    z-index: 750; /* nav (800) erişilebilir kalır, RPM (1010) üstte */
    pointer-events: none;
  }
  .letterbox--top { top: 0; transform: translateY(-101%); }
  .letterbox--bot { bottom: 0; transform: translateY(101%); }

  @media (max-width: 900px) {
    .hud { display: none; }
    .slate { top: 4.4rem; max-width: 92vw; white-space: normal; text-align: center; }
  }
</style>
