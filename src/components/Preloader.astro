---
// Jenerik açılış: "BİR KARMOT PRODÜKSİYONU" + kontak marşı + /// perde
---

<div class="pre" id="pre" aria-hidden="true">
  <div class="pre__stage">
    <p class="mono-label pre__kicker" id="preKicker">Bir Karmot Prodüksiyonu</p>
    <p class="display display-italic pre__title" id="preTitle">Gücü <span class="metal-text">Aktarıyoruz</span></p>
    <div class="pre__meter">
      <div class="pre__bar" id="preBar"></div>
    </div>
    <p class="mono-label pre__pct"><span id="prePct">000</span>% — Tork Yükleniyor</p>
    <p class="mono-label pre__spec" id="preSpec">35mm · 2.39:1 · 24 kare/sn · tek çekim</p>
  </div>
  <div class="pre__wipe" aria-hidden="true">
    <i class="pre__blade" id="blade1"></i>
    <i class="pre__blade" id="blade2"></i>
    <i class="pre__blade" id="blade3"></i>
  </div>
</div>

<style>
  .pre {
    position: fixed;
    inset: 0;
    z-index: 1500;
    background: var(--navy-950);
    display: grid;
    place-items: center;
  }
  .pre__stage {
    text-align: center;
    display: grid;
    justify-items: center;
    gap: 1.1rem;
  }
  .pre__kicker { color: var(--text-dim); }
  .pre__title { font-size: clamp(2rem, 5.5vw, 4.2rem); color: #fff; }
  .pre__meter {
    width: min(340px, 60vw);
    height: 2px;
    background: var(--line);
    overflow: hidden;
  }
  .pre__bar {
    height: 100%;
    width: 100%;
    background: var(--grad-energy);
    transform: scaleX(0);
    transform-origin: left;
  }
  .pre__pct { color: var(--blue-300); }
  .pre__spec { color: var(--text-dim); opacity: 0.55; font-size: 0.62rem; }

  .pre__wipe {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }
  .pre__blade {
    position: absolute;
    top: -20%;
    height: 140%;
    width: 46%;
    transform: skewX(var(--slash-skew)) translateX(-260%);
    will-change: transform;
  }
  .pre__blade:nth-child(1) { left: 4%; background: var(--blue-500); }
  .pre__blade:nth-child(2) { left: 34%; background: var(--navy-800); }
  .pre__blade:nth-child(3) { left: 64%; background: var(--grad-metal); }
</style>
