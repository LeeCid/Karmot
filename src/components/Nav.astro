---
import karmotLogo from '../assets/karmot-logo.svg';
---

<nav class="nav" id="nav">
  <a class="nav__brand" href="/" aria-label="Karmot ana sayfa">
    <img src={karmotLogo.src} alt="Karmot Güç Aktarım Sistemleri" width="156" height="37" />
  </a>
  <div class="nav__links">
    <a class="mono-label nav__link" href="/#neden">Karmot</a>
    <a class="mono-label nav__link" href="/#surec">Nasıl Çalışırız</a>
    <a class="mono-label nav__link" href="/hakkimizda">Kurumsal</a>
    <a class="mono-label nav__link" href="/#katalog">Katalog</a>
  </div>
  <a class="btn nav__cta" href="/#iletisim">Talep İlet</a>
</nav>

<style>
  .nav {
    position: fixed;
    inset: 0 0 auto 0;
    z-index: 800;
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.85rem var(--gutter);
    transition: background 0.4s ease, box-shadow 0.4s ease;
  }
  .nav.is-scrolled {
    background: color-mix(in srgb, var(--navy-950) 82%, transparent);
    backdrop-filter: blur(12px);
    box-shadow: 0 1px 0 var(--line);
  }
  .nav__brand img {
    height: 34px;
    width: auto;
    filter: brightness(0) invert(1);
  }
  .nav__links {
    display: flex;
    gap: 1.8rem;
    margin-left: auto;
  }
  .nav__link {
    color: var(--text-dim);
    transition: color 0.25s ease;
  }
  .nav__link:hover { color: #fff; }
  .nav__cta {
    padding: 0.65em 1.4em;
    font-size: 0.8rem;
    white-space: nowrap;
  }
  @media (max-width: 980px) {
    .nav { gap: 1.1rem; }
    .nav__links { gap: 0.85rem; }
    .nav__link { font-size: 0.62rem; }
  }
  @media (max-width: 760px) {
    .nav__links { display: none; }
    .nav__cta { margin-left: auto; }
  }
</style>
