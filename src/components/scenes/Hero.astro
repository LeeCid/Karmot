---
// Sahne 01 — Sessizlik: pinlenmiş kinetik açılış + çift katmanlı volan
const TICKS = 48;
const ticks = Array.from({ length: TICKS }, (_, i) => {
  const a = ((i * 360) / TICKS) * (Math.PI / 180);
  return {
    x1: 450 + Math.sin(a) * 398,
    y1: 450 - Math.cos(a) * 398,
    x2: 450 + Math.sin(a) * (i % 4 === 0 ? 318 : 352),
    y2: 450 - Math.cos(a) * (i % 4 === 0 ? 318 : 352),
    w: i % 4 === 0 ? 5 : 2,
  };
});

// dönüşü okunur kılan indeks yayı (-20°…20°, r 419)
const idxArc = (() => {
  const r = 419;
  const p = (deg: number) => {
    const a = (deg * Math.PI) / 180;
    return `${450 + Math.sin(a) * r} ${450 - Math.cos(a) * r}`;
  };
  return `M ${p(-20)} A ${r} ${r} 0 0 1 ${p(20)}`;
})();

// iç göbek kolları (logo slash ritmi: 3 kol)
const spokes = [0, 120, 240].map((deg) => {
  const a = (deg * Math.PI) / 180;
  return {
    x1: 450 + Math.sin(a) * 70,
    y1: 450 - Math.cos(a) * 70,
    x2: 450 + Math.sin(a) * 238,
    y2: 450 - Math.cos(a) * 238,
  };
});
---

<section class="hero blueprint-bg" id="hero">
  <div class="hero__glow" aria-hidden="true"></div>

  <svg class="hero__rotor" viewBox="0 0 900 900" aria-hidden="true">
    <g id="rotorOuter">
      <circle cx="450" cy="450" r="420" fill="none" stroke="currentColor" stroke-width="1.5" />
      {ticks.map((t) => (
        <line x1={t.x1} y1={t.y1} x2={t.x2} y2={t.y2} stroke="currentColor" stroke-width={t.w} />
      ))}
      <path d={idxArc} fill="none" stroke="#1e88c7" stroke-width="6" opacity="0.75" />
    </g>
    <g id="rotorInner">
      <circle cx="450" cy="450" r="252" fill="none" stroke="currentColor" stroke-width="1.5" stroke-dasharray="4 14" />
      {spokes.map((s) => (
        <line x1={s.x1} y1={s.y1} x2={s.x2} y2={s.y2} stroke="currentColor" stroke-width="7" stroke-linecap="round" />
      ))}
      <circle cx="450" cy="450" r="56" fill="none" stroke="currentColor" stroke-width="3" />
      <circle cx="450" cy="450" r="10" fill="currentColor" />
    </g>
  </svg>

  <span class="hero__ghost display display-italic" aria-hidden="true">Tork</span>

  <i class="hero__corner hero__corner--tl" aria-hidden="true"></i>
  <i class="hero__corner hero__corner--tr" aria-hidden="true"></i>
  <i class="hero__corner hero__corner--bl" aria-hidden="true"></i>
  <i class="hero__corner hero__corner--br" aria-hidden="true"></i>

  <div class="container hero__inner">
    <p class="mono-label hero__kicker">Karmot Güç Aktarım Sistemleri sunar</p>

    <div class="hero__stage">
      <h1 class="display hero__t1" aria-label="Her şey durur… ta ki güç aktarılana kadar.">
        <span class="kin"><span class="kin-line">Her şey</span></span>
        <span class="kin"><span class="kin-line">durur<span class="hero__dots">…</span></span></span>
      </h1>
      <p class="display hero__t2" aria-hidden="true">
        <span class="kin"><span class="kin-line display-italic">ta ki <em class="metal-text sheen">güç</em></span></span>
        <span class="kin"><span class="kin-line display-italic metal-text sheen">aktarılana</span></span>
        <span class="kin"><span class="kin-line">kadar.</span></span>
      </p>
    </div>

    <div class="hero__foot">
      <span class="slashes" aria-hidden="true"><i></i><i></i><i></i></span>
      <p class="hero__lede text-dim">
        Motor değil, <strong>hareket</strong> satıyoruz. Bantları, vinçleri, karıştırıcıları döndüren
        güç — yedi markanın gücü tek tedarik hattında.
      </p>
      <div class="hero__cta">
        <a class="btn" href="#iletisim">Teklif Alın</a>
        <a class="btn btn--ghost" href="#zincir">Zinciri Keşfedin</a>
      </div>
    </div>
  </div>

  <p class="hero__hint mono-label" aria-hidden="true">
    Kaydırın — güç hattını takip edin
    <span class="hero__hint-line"></span>
  </p>
</section>

<style>
  .hero {
    min-height: 100svh;
    display: grid;
    align-items: center;
    overflow: clip;
    position: relative;
  }
  .hero__glow {
    position: absolute;
    top: -20%;
    right: -25%;
    width: 95vmin;
    height: 95vmin;
    background: radial-gradient(circle, rgba(0, 105, 169, 0.22), transparent 62%);
    pointer-events: none;
  }
  .hero__rotor {
    position: absolute;
    top: 50%;
    right: -18vmin;
    width: 118vmin;
    height: 118vmin;
    margin-top: -59vmin;
    color: var(--blue-300);
    opacity: 0.15;
    pointer-events: none;
  }
  .hero__rotor g {
    will-change: transform;
  }
  .hero__ghost {
    position: absolute;
    right: -2vw;
    top: 3%;
    font-size: clamp(9rem, 24vw, 26rem);
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(86, 174, 222, 0.09);
    pointer-events: none;
    z-index: 1;
    will-change: transform;
  }

  .hero__corner {
    position: absolute;
    width: 22px;
    height: 22px;
    border: 0 solid rgba(198, 198, 198, 0.4);
    z-index: 3;
    pointer-events: none;
  }
  .hero__corner--tl { top: 5rem; left: 1.2rem; border-top-width: 2px; border-left-width: 2px; }
  .hero__corner--tr { top: 5rem; right: 1.2rem; border-top-width: 2px; border-right-width: 2px; }
  .hero__corner--bl { bottom: 4.4rem; left: 1.2rem; border-bottom-width: 2px; border-left-width: 2px; }
  .hero__corner--br { bottom: 4.4rem; right: 1.2rem; border-bottom-width: 2px; border-right-width: 2px; }

  .hero__inner {
    position: relative;
    z-index: 2;
    padding-block: 7rem 5rem;
  }
  .hero__kicker { margin-bottom: 1.4rem; }
  .hero__stage {
    display: grid;
  }
  .hero__stage > * {
    grid-area: 1 / 1;
  }
  .hero__t1,
  .hero__t2 {
    font-size: var(--fs-hero);
  }
  .hero__dots { color: var(--blue-400); }
  .kin {
    display: block;
    overflow: clip;
    padding-block: 0.05em;
  }
  .kin-line {
    display: inline-block;
    will-change: transform;
  }
  .hero__foot {
    margin-top: 2.6rem;
    max-width: 46rem;
  }
  .hero__foot .slashes {
    font-size: 1rem;
    margin-bottom: 0.9rem;
  }
  .hero__lede strong { color: var(--blue-300); }
  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: 1.8rem;
  }
  .hero__hint {
    position: absolute;
    bottom: 1.4rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    align-items: center;
    gap: 0.9em;
    color: var(--text-dim);
    z-index: 2;
    white-space: nowrap;
  }
  .hero__hint-line {
    width: 54px;
    height: 1.5px;
    background: linear-gradient(90deg, var(--blue-400), transparent);
    animation: hint-flow 1.6s var(--ease-snap) infinite;
    transform-origin: left;
  }
  @keyframes hint-flow {
    0% { transform: scaleX(0); opacity: 1; }
    70% { transform: scaleX(1); opacity: 1; }
    100% { transform: scaleX(1); opacity: 0; }
  }

  /* Masaüstü pin akışı: t2 konumu tamamen GSAP'te (CSS transform GSAP'in
     yPercent'iyle çakışıp px olarak yapışıyor); foot girişte gizli */
  @media (min-width: 900px) and (prefers-reduced-motion: no-preference) {
    .hero__foot { opacity: 0; visibility: hidden; }
  }
  /* Mobil / reduced: iki blok alt alta, hepsi görünür */
  @media (max-width: 899.98px), (prefers-reduced-motion: reduce) {
    .hero__stage > * { grid-area: auto; }
    .hero__t2 { margin-top: 0.3em; }
    .hero__corner { display: none; }
    .hero__ghost { font-size: 8rem; top: 1%; }
  }
</style>
