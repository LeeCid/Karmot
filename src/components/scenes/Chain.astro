---
// Sahne 02 — Güç Zinciri: yatay pinlenmiş tahrik hattı
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const brands = (await getCollection('brands')).sort((a, b) => a.data.order - b.data.order);
const starImgs = import.meta.glob<{ default: ImageMetadata }>('../../assets/products/stars/*.png', {
  eager: true,
});
const starsFor = (id: string) =>
  Object.keys(starImgs)
    .filter((k) => k.includes(`/${id}-star-`))
    .sort()
    .map((k) => starImgs[k].default);

// kaplin (shaft bağlantısı) çubukları
const spokes = Array.from({ length: 8 }, (_, i) => (i * 360) / 8);
---

<section class="chain" id="zincir">
  <div class="chain__hud">
    <p class="mono-label chain__hudlabel">
      Güç Aktarımı <span class="chain__meter"><i id="chainBar"></i></span>
      <span id="chainPct">%0</span> · <span id="chainCount">Halka 0 / {brands.length}</span>
    </p>
  </div>

  <div class="chain__track" id="chainTrack">
    <div class="chain__shaft" aria-hidden="true"></div>
    <div class="chain__ruler" aria-hidden="true"></div>

    <article class="panel panel--intro">
      <div class="panel__body">
        <p class="mono-label">Sahne 02 · Perde açılıyor</p>
        <h2 class="display panel__title">Güç <em class="display-italic metal-text sheen">Zinciri</em></h2>
        <p class="text-dim panel__lede">
          Enerjiden harekete yedi halka. Her halka bir marka, her marka işinin ustası.
          Hat ilerledikçe tork sağa aktarılır — kaydırmaya devam edin.
        </p>
        <span class="slashes" aria-hidden="true"><i></i><i></i><i></i></span>
      </div>
    </article>

    {brands.map((b) => {
      const stars = starsFor(b.id);
      return (
        <article class="panel" data-brand={b.id}>
          <span class="panel__ghost display" aria-hidden="true">{String(b.data.order).padStart(2, '0')}</span>
          <svg class="coupling" viewBox="0 0 200 200" aria-hidden="true">
            <circle cx="100" cy="100" r="92" fill="none" stroke="currentColor" stroke-width="1.5" />
            <circle cx="100" cy="100" r="64" fill="none" stroke="currentColor" stroke-width="1" stroke-dasharray="3 9" />
            {spokes.map((a) => (
              <line
                x1={100 + Math.sin((a * Math.PI) / 180) * 22}
                y1={100 - Math.cos((a * Math.PI) / 180) * 22}
                x2={100 + Math.sin((a * Math.PI) / 180) * 88}
                y2={100 - Math.cos((a * Math.PI) / 180) * 88}
                stroke="currentColor"
                stroke-width="2"
              />
            ))}
            <circle cx="100" cy="100" r="14" fill="none" stroke="currentColor" stroke-width="3" />
          </svg>
          <div class="panel__body">
            <p class="mono-label panel__role">Görev {b.data.roleNo} — {b.data.role}</p>
            <h3 class="display panel__name">{b.data.name}</h3>
            <p class="display-italic panel__tag">{b.data.tagline}</p>
            {stars.length > 0 && (
              <figure class="stars" data-stars>
                <div class="stars__stage">
                  <span class="stars__spot" aria-hidden="true"></span>
                  {stars.map((s, i) => (
                    <Image
                      class="stars__item"
                      src={s}
                      alt={`${b.data.name} ürünü ${i + 1}`}
                      height={300}
                      quality={85}
                      loading="eager"
                    />
                  ))}
                </div>
                <figcaption class="stars__caption" aria-hidden="true">
                  <span class="mono-label stars__lead">Başrolde — {b.data.name}</span>
                  <span class="mono-label stars__counter">01 / {String(stars.length).padStart(2, '0')}</span>
                </figcaption>
              </figure>
            )}
            <p class="text-dim panel__desc">{b.data.description}</p>
            <div class="panel__specs" role="list">
              {b.data.specs.slice(0, 3).map((s) => (
                <span class="panel__chip" role="listitem">
                  <b>{s.k}</b> {s.v}
                </span>
              ))}
            </div>
            <a class="panel__link mono-label" href={`/markalar/${b.id}`}>Ürünleri Gör ///</a>
          </div>
        </article>
      );
    })}

    <article class="panel panel--outro">
      <div class="panel__body">
        <p class="mono-label">Zincir tamam</p>
        <h2 class="display panel__title">Tork <em class="display-italic metal-text sheen">yerine ulaştı.</em></h2>
        <p class="text-dim panel__lede">Sırada kanıt var — ışıkları açıyoruz.</p>
      </div>
    </article>
  </div>
</section>

<style>
  .chain {
    position: relative;
    overflow: clip;
    background:
      radial-gradient(120vmin 80vmin at 70% 20%, rgba(0, 105, 169, 0.12), transparent 60%),
      var(--navy-950);
  }
  .chain__hud {
    position: absolute;
    top: 4.6rem;
    left: 0;
    right: 0;
    z-index: 5;
    display: flex;
    justify-content: center;
    pointer-events: none;
  }
  .chain__hudlabel {
    display: flex;
    align-items: center;
    gap: 0.9em;
    color: var(--text-dim);
  }
  .chain__meter {
    width: clamp(120px, 22vw, 300px);
    height: 2px;
    background: var(--line);
    display: inline-block;
    overflow: hidden;
  }
  .chain__meter i {
    display: block;
    height: 100%;
    background: var(--grad-energy);
    transform: scaleX(0);
    transform-origin: left;
  }

  .chain__track {
    display: flex;
    align-items: stretch;
    width: max-content;
    position: relative;
    will-change: transform;
  }
  .chain__shaft {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 2px;
    background-image: repeating-linear-gradient(
      90deg,
      var(--blue-500) 0 26px,
      rgba(86, 174, 222, 0.25) 26px 52px
    );
    background-size: 52px 2px;
    opacity: 0.65;
  }
  /* şaft altı ölçü cetveli: teknik çizim ekseni hissi */
  .chain__ruler {
    position: absolute;
    left: 0;
    right: 0;
    top: calc(50% + 10px);
    height: 12px;
    background-image:
      repeating-linear-gradient(90deg, rgba(86, 174, 222, 0.45) 0 1.5px, transparent 1.5px 130px),
      repeating-linear-gradient(90deg, rgba(159, 176, 201, 0.22) 0 1px, transparent 1px 26px);
    background-size: auto 12px, auto 6px;
    background-repeat: repeat-x;
    background-position: 0 0, 0 0;
    opacity: 0.8;
  }

  .panel {
    width: 74vw;
    min-height: 100svh;
    display: grid;
    align-items: center;
    position: relative;
    padding: clamp(8rem, 14vh, 9.5rem) clamp(2rem, 6vw, 6rem) clamp(4rem, 7vh, 5.5rem);
    border-right: 1px solid rgba(159, 176, 201, 0.09);
  }
  .panel--intro, .panel--outro { width: 62vw; }
  .panel__body {
    position: relative;
    z-index: 3;
    max-width: 34rem;
  }
  .panel__ghost {
    position: absolute;
    right: 2vw;
    bottom: -4vh;
    font-size: 36vh;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.5px rgba(86, 174, 222, 0.16);
    filter: drop-shadow(0 0 22px rgba(86, 174, 222, 0.1));
    z-index: 1;
    pointer-events: none;
  }
  .coupling {
    --cs: clamp(220px, 30vh, 340px);
    position: absolute;
    top: calc(50% - var(--cs) / 2);
    left: calc(50% - var(--cs) / 2);
    width: var(--cs);
    height: var(--cs);
    color: rgba(86, 174, 222, 0.14);
    z-index: 0;
    will-change: transform;
  }
  .panel__title { font-size: var(--fs-display); margin-block: 0.6rem 1rem; }
  .panel__lede { max-width: 30rem; margin-bottom: 1.4rem; }
  .panel__role { color: var(--blue-300); }
  .panel__name { font-size: clamp(2.6rem, 6vw, 5rem); margin-block: 0.35em 0.15em; }
  .panel__tag {
    font-family: var(--font-display);
    font-variation-settings: 'wdth' 112;
    font-weight: 600;
    color: var(--steel-300);
    margin-bottom: 1.3rem;
  }

  /* Başrolde: ürünler karanlık sahnede, spot altında teker teker */
  .stars {
    margin: 0 0 1.3rem;
  }
  .stars__stage {
    position: relative;
    height: clamp(180px, 27vh, 250px);
    display: grid;
    place-items: center;
    overflow: visible;
  }
  .stars__spot {
    position: absolute;
    inset: -14% -18%;
    background: radial-gradient(
      52% 64% at 50% 56%,
      rgba(86, 174, 222, 0.17),
      rgba(0, 105, 169, 0.05) 55%,
      transparent 76%
    );
    pointer-events: none;
  }
  /* zemin gölgesi: yıldız sahneye basar, havada süzülmez */
  .stars__stage::after {
    content: '';
    position: absolute;
    bottom: 2px;
    left: 50%;
    width: 54%;
    height: 16px;
    transform: translateX(-50%);
    background: radial-gradient(50% 50% at 50% 50%, rgba(2, 5, 12, 0.55), transparent 72%);
    filter: blur(4px);
  }
  .stars :global(.stars__item) {
    position: absolute;
    max-height: 86%;
    max-width: 84%;
    width: auto;
    height: auto;
    object-fit: contain;
    opacity: 0;
    filter: drop-shadow(0 18px 30px rgba(2, 6, 14, 0.6));
    will-change: transform, opacity;
    z-index: 1;
  }
  .stars :global(.stars__item:first-child) {
    opacity: 1; /* JS yokken / reduced'da ilk yıldız sahnede */
  }
  .stars__caption {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--line);
    padding-top: 0.55rem;
    margin-top: 0.2rem;
  }
  .stars__lead { color: var(--blue-300); }
  .stars__counter { color: var(--steel-500); }

  .panel__desc {
    font-size: 0.95rem;
    max-width: 44ch;
    margin-bottom: 1.2rem;
  }
  .panel__specs {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 1.4rem;
  }
  .panel__chip {
    font-family: var(--font-mono);
    font-size: 0.68rem;
    letter-spacing: 0.06em;
    padding: 0.5em 0.9em;
    border: 1px solid var(--line);
    color: var(--steel-300);
    white-space: nowrap;
  }
  .panel__chip b { color: var(--blue-300); font-weight: 700; margin-right: 0.5em; }
  .panel__link { color: var(--blue-300); }
  .panel__link:hover { color: #fff; }

  /* Dar pencere: paneller genişler, sinema devam eder */
  @media (max-width: 1000px) {
    .panel { width: 86vw; }
    .panel--intro, .panel--outro { width: 78vw; }
    .panel__ghost { font-size: 26vh; }
  }

  /* Mobil: dikey akış */
  @media (max-width: 679.98px), (prefers-reduced-motion: reduce) {
    .chain__hud { display: none; }
    .chain__ruler { display: none; }
    .chain__track { display: block; width: auto; }
    .chain__shaft {
      left: calc(var(--gutter) - 1px);
      right: auto;
      top: 0;
      bottom: 0;
      width: 2px;
      height: auto;
      background-image: repeating-linear-gradient(
        180deg,
        var(--blue-500) 0 26px,
        rgba(86, 174, 222, 0.25) 26px 52px
      );
      background-size: 2px 52px;
    }
    .panel {
      width: 100%;
      min-height: 0;
      border-right: 0;
      padding: 3.6rem var(--gutter) 3.2rem calc(var(--gutter) + 1.6rem);
    }
    .panel--intro, .panel--outro { width: 100%; }
    .panel__ghost { font-size: 8rem; right: 0.4rem; bottom: 0.4rem; }
    .coupling { display: none; }
  }
</style>
