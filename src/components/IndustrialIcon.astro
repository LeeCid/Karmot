---
type IndustrialIconName = 'motor' | 'gearbox' | 'brake' | 'vibration' | 'exproof' |
  'pump' | 'fan' |
  'request' | 'compare' | 'delivery' | 'contact' | 'options' | 'tracking';

interface Props {
  name: IndustrialIconName;
  title?: string;
  class?: string;
}

const { name, title, class: className } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 64 64"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  stroke="currentColor"
  stroke-width="2.2"
  stroke-linecap="round"
  stroke-linejoin="round"
  role={title ? 'img' : undefined}
  aria-hidden={title ? undefined : 'true'}
  focusable="false"
>
  {title && <title>{title}</title>}

  {name === 'motor' && (
    <g>
      <path d="M7 34h9M5 31v6M16 25v18c0 3 2 5 5 5h26c3 0 5-2 5-5V25c0-3-2-5-5-5H21c-3 0-5 2-5 5Z" />
      <path d="M52 27h4c2 0 3 1 3 3v8c0 2-1 3-3 3h-4M25 20v-6h15v6M22 27v14M28 24v20M34 24v20M40 24v20M46 27v14M12 49h45" />
    </g>
  )}

  {name === 'gearbox' && (
    <g>
      <path d="M6 34h10M49 34h9M16 24l7-6h22l7 8v18l-8 7H22l-7-8 1-19Z" />
      <circle cx="36" cy="35" r="10" />
      <circle cx="36" cy="35" r="3.5" />
      <path d="M36 21v4M36 45v4M22 35h4M46 35h4M26 25l3 3M43 42l3 3M46 25l-3 3M29 42l-3 3" />
      <circle cx="22" cy="28" r="4" />
    </g>
  )}

  {name === 'brake' && (
    <g>
      <circle cx="32" cy="33" r="18" />
      <circle cx="32" cy="33" r="7" />
      <path d="M32 15v7M32 44v7M14 33h7M43 33h7M19 20l6 6M39 40l6 6M45 20l-6 6M25 40l-6 6" />
      <path d="M19 12h8l2 4M45 12h-8l-2 4M19 54h8l2-4M45 54h-8l-2-4" />
    </g>
  )}

  {name === 'vibration' && (
    <g>
      <path d="M19 25h26v20H19zM25 25v20M32 25v20M39 25v20M14 29h5v12h-5c-2 0-3-2-3-4v-4c0-2 1-4 3-4ZM45 29h5c2 0 3 2 3 4v4c0 2-1 4-3 4h-5" />
      <path d="M7 25c-5 5-5 15 0 20M57 25c5 5 5 15 0 20M3 19c-9 9-9 23 0 32M61 19c9 9 9 23 0 32M15 49h34" />
    </g>
  )}

  {name === 'exproof' && (
    <g>
      <path d="M5 33h8M4 30v6M13 24v18c0 3 2 5 5 5h25c3 0 5-2 5-5V24c0-3-2-5-5-5H18c-3 0-5 2-5 5ZM22 19v-7h16v7M19 26v15M25 23v21M31 23v21M37 23v21M43 26v15M10 48h39" />
      <path d="M48 36l10 4v7c0 7-4 11-10 14-6-3-10-7-10-14v-2" />
      <path d="M48 42c-3 4-3 8 0 11 3-3 4-6 1-9 0 2-1 2-1-2Z" />
    </g>
  )}

  {name === 'pump' && (
    <g>
      <circle cx="27" cy="33" r="15" />
      <circle cx="27" cy="33" r="5" />
      <path d="M27 18v-6h-8M27 18h8c6 0 11 5 11 11v4M42 33h11v8H42zM27 48v6h12M12 33H6v13h9" />
      <path d="M27 28c3 0 5 2 5 5M14 54h32" />
    </g>
  )}

  {name === 'fan' && (
    <g>
      <circle cx="32" cy="30" r="19" />
      <circle cx="32" cy="30" r="4" />
      <path d="M32 26c0-6 3-10 8-11 2 4 1 9-4 12M36 32c6 0 10 3 11 8-4 2-9 1-12-4M28 34c0 6-3 10-8 11-2-4-1-9 4-12M28 28c-6 0-10-3-11-8 4-2 9-1 12 4" />
      <path d="M18 46 12 54h40l-6-8M24 54v-6M40 54v-6" />
    </g>
  )}

  {name === 'request' && (
    <g>
      <path d="M15 13h34v38H15zM21 20h12M21 27h22M21 34h14M21 41h9" />
      <circle cx="42" cy="42" r="8" />
      <path d="m48 48 6 6M11 20v-9h9M44 11h9v9M53 44v9h-9M20 53h-9v-9" />
    </g>
  )}

  {name === 'compare' && (
    <g>
      <rect x="8" y="13" width="19" height="38" rx="2" />
      <rect x="37" y="13" width="19" height="38" rx="2" />
      <path d="M13 22h9M13 29h7M42 22h9M42 29h7M28 35h8M32 31l4 4-4 4" />
      <path d="m13 41 3 3 6-7M42 41h9" />
    </g>
  )}

  {name === 'delivery' && (
    <g>
      <path d="M7 18h31v27H7zM38 28h10l9 9v8H38zM44 28v9h13M13 18l7 7 7-7M20 25v11" />
      <circle cx="17" cy="49" r="4" />
      <circle cx="49" cy="49" r="4" />
      <path d="M25 49h20" />
    </g>
  )}

  {name === 'contact' && (
    <g>
      <circle cx="25" cy="21" r="7" />
      <path d="M11 52c1-11 6-18 14-18s13 7 14 18M15 21a10 10 0 0 1 20 0v7M15 25v6h5M35 25v6h-5M35 31c0 4-3 7-8 7" />
      <path d="M41 12h15v12H45l-4 5V12ZM46 18h5" />
    </g>
  )}

  {name === 'options' && (
    <g>
      <path d="M13 15h38v10H13zM13 28h38v10H13zM13 41h38v10H13z" />
      <circle cx="20" cy="20" r="2" />
      <circle cx="20" cy="33" r="2" />
      <circle cx="20" cy="46" r="2" />
      <path d="M27 20h17M27 33h11M27 46h14M43 31l3 3 6-7" />
    </g>
  )}

  {name === 'tracking' && (
    <g>
      <path d="M10 48h10V32h18V16h15" stroke-dasharray="4 4" />
      <circle cx="10" cy="48" r="4" />
      <circle cx="20" cy="32" r="4" />
      <circle cx="38" cy="16" r="4" />
      <circle cx="53" cy="16" r="7" />
      <path d="m49 16 3 3 6-7M27 48h27M49 43l5 5-5 5" />
    </g>
  )}
</svg>
