---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Rpm from '../components/Rpm.astro';
import karmotLogo from '../assets/karmot-logo.svg';

const brands = (await getCollection('brands')).sort((a, b) => a.data.order - b.data.order);

const promises = [
  {
    t: 'Tek muhatap',
    d: 'Talep, teklif ve sipariş aynı Karmot akışında ilerler.',
  },
  {
    t: 'Açık seçenekler',
    d: 'Stok, termin ve uygun alternatifler net biçimde önünüzdedir.',
  },
  {
    t: 'Süreç takibi',
    d: 'Onaydan teslimata kadar işi Karmot takip eder.',
  },
];

const why = [
  {
    t: 'Talebi doğru anlarız',
    d: 'Kodunuz hazırsa hızlı ilerleriz; değilse etiket veya uygulama bilgisini birlikte netleştiririz.',
  },
  {
    t: 'Seçenekleri açık sunarız',
    d: 'Stok, termin ve uygun alternatifleri artılarıyla birlikte tek tabloda önünüze koyarız.',
  },
  {
    t: 'Süreci sahipleniriz',
    d: 'Tekliften sevkiyata kadar farklı kişiler arasında dolaşmadan tek bir Karmot muhatabıyla ilerlersiniz.',
  },
  {
    t: 'Teslimattan sonra da buradayız',
    d: 'Ürün sahaya ulaştığında teknik veya servis ihtiyacınızı doğru kanala ulaştırırız.',
  },
];

const steps = [
  {
    n: '01',
    t: 'Talebi paylaşın',
    d: 'Ürün kodunu, etiket fotoğrafını veya ihtiyacınızı gönderin.',
  },
  {
    n: '02',
    t: 'Net teklif alın',
    d: 'Uygun seçenekleri stok, fiyat ve termin bilgisiyle birlikte sunalım.',
  },
  {
    n: '03',
    t: 'Karmot takip etsin',
    d: 'Onaydan sevkiyata kadar süreci biz izleyelim; siz işinize devam edin.',
  },
];

const faq = [
  {
    q: 'Ürün kodunu biliyorum; nasıl hızlı teklif alırım?',
    a: 'Kod, adet ve teslimat bilgisini e-postayla paylaşın. Varsa etiket fotoğrafını ekleyin; Karmot stok ve termin seçeneklerini tek teklifte netleştirsin.',
  },
  {
    q: 'Koddan emin değilsem yardımcı olur musunuz?',
    a: 'Evet. Etiket fotoğrafı, mevcut ürün bilgisi veya uygulama detayları üzerinden ihtiyacı birlikte netleştiririz.',
  },
  {
    q: 'Stokta yoksa ne olur?',
    a: 'Beklenen tedarik süresini ve varsa teknik olarak uygun alternatifleri açıkça paylaşırız; seçimi sizin onayınızla ilerletiriz.',
  },
  {
    q: 'Farklı ürün gruplarını tek siparişte toplayabilir miyim?',
    a: 'Karmot’un tedarik kapsamındaki motor, redüktör, fren ve vibrasyon ihtiyaçlarını tek sipariş akışında birleştirebilirsiniz.',
  },
  {
    q: 'Teslimattan sonra kime ulaşırım?',
    a: 'Sipariş sırasında görüştüğünüz Karmot muhatabı teknik veya servis ihtiyacınızı doğru kanala yönlendirir.',
  },
];

const groups = [
  { t: 'Elektrik Motorları', brands: 'Gamak · WEG · WAT', href: '/markalar' },
  { t: 'Redüktörler', brands: 'Dinamik', href: '/markalar/dinamik' },
  { t: 'Fren Sistemleri', brands: 'Enarc', href: '/markalar/enarc' },
  { t: 'Vibrasyon Motorları', brands: 'Avibro', href: '/markalar/avibro' },
  { t: 'Exproof Motorlar', brands: 'Pro-Ex', href: '/markalar/pro-ex' },
];
---

<Base
  title="Karmot | Endüstriyel Güç Aktarım Sistemleri Tedarikçisi"
  description="Karmot; elektrik motoru, redüktör, fren ve vibrasyon ihtiyaçlarında açık stok ve termin bilgisi, uygun alternatifler ve tek muhatapla tedarik sürecini kolaylaştırır."
>
  <Nav />

  <main>
    <section class="hero blueprint-bg" id="hero">
      <div class="hero__glow" aria-hidden="true"></div>
      <div class="container hero__grid">
        <div class="hero__copy">
          <p class="mono-label reveal">Karmot / Endüstriyel tedarik ortağınız</p>
          <h1 class="display hero__title">
            <span class="kin"><span class="kin-line metal-text">Karmot.</span></span>
            <span class="kin"><span class="kin-line">Tedarik bizde,</span></span>
            <span class="kin"><span class="kin-line display-italic">üretim sizde.</span></span>
          </h1>
          <p class="hero__lede text-dim reveal">
            Ürünü zaten biliyor olabilirsiniz. Karmot; doğru kodu teyit eder, stok ve termin
            seçeneklerini karşılaştırır, tekliften teslimata kadar süreci tek elden yürütür.
          </p>
          <div class="hero__cta reveal">
            <a class="btn" href="#iletisim">Talebinizi İletin</a>
            <a class="btn btn--ghost" href="#neden">Neden Karmot?</a>
          </div>
          <p class="mono-label hero__note reveal">Net bilgi · Uygun seçenek · Tek muhatap</p>
        </div>

        <aside class="hero__panel reveal" aria-label="Karmot çalışma akışı">
          <div class="hero__panel-top">
            <span class="mono-label">Karmot operasyon akışı</span>
            <span class="hero__status"><i aria-hidden="true"></i> Aktif</span>
          </div>
          <ol class="hero__flow">
            <li><span>01</span><strong>Talep</strong><small>Kod veya ihtiyaç</small></li>
            <li><span>02</span><strong>Seçenek</strong><small>Stok · fiyat · termin</small></li>
            <li><span>03</span><strong>Teslimat</strong><small>Tek noktadan takip</small></li>
          </ol>
          <div class="hero__k" aria-hidden="true">K</div>
        </aside>
      </div>
    </section>

    <section class="promise-strip" aria-label="Karmot tedarik yaklaşımı">
      <div class="container promise-strip__grid">
        {promises.map((promise, i) => (
          <article class="promise-strip__item reveal">
            <span class="mono-label">0{i + 1} ///</span>
            <div>
              <h2 class="display">{promise.t}</h2>
              <p>{promise.d}</p>
            </div>
          </article>
        ))}
      </div>
    </section>

    <section class="section section--light why" id="neden">
      <div class="container">
        <div class="why__intro">
          <div>
            <p class="mono-label reveal">Karmot neyi farklı yapar?</p>
            <h2 class="display why__title reveal">
              Ürünü değil,<br />
              <em class="display-italic why__em">tedarik sürecini</em> çözeriz.
            </h2>
          </div>
          <p class="why__lede reveal">
            Müşterimiz ürünü çoğu zaman zaten bilir. Karmot’un işi; doğru kodu doğrulamak,
            seçenekleri karşılaştırmak, stok ve termini netleştirmek, siparişten teslimata
            kadar süreci takip etmektir.
          </p>
        </div>

        <div class="why__grid">
          {why.map((item, i) => (
            <article class="why__card reveal">
              <span class="mono-label why__no">{String(i + 1).padStart(2, '0')} ///</span>
              <h3 class="display why__t">{item.t}</h3>
              <p class="why__d">{item.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--light process" id="surec">
      <div class="container">
        <p class="mono-label reveal">Nasıl çalışırız?</p>
        <h2 class="display process__title reveal">Talebinizden teslimata, <em class="display-italic">tek akış.</em></h2>
        <div class="process__grid">
          {steps.map((step) => (
            <article class="process__step reveal">
              <span class="display process__n">{step.n}</span>
              <div>
                <h3 class="display process__t">{step.t}</h3>
                <p class="process__d">{step.d}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--light faq" id="sss">
      <div class="container faq__grid">
        <div class="faq__head">
          <p class="mono-label reveal">Satın almadan önce</p>
          <h2 class="display faq__title reveal">
            Sık sorulanlar,<br /><em class="display-italic faq__em">net cevaplar.</em>
          </h2>
          <p class="faq__lede reveal">
            Aradığınız cevap burada yoksa ürün kodunu veya etiket fotoğrafını gönderin;
            Karmot sizin için netleştirsin.
          </p>
          <a class="btn reveal" href="#iletisim">Talebinizi İletin</a>
        </div>
        <div class="faq__list">
          {faq.map((item) => (
            <details class="faq__item reveal">
              <summary class="faq__q">
                <span>{item.q}</span>
                <i class="faq__plus" aria-hidden="true"></i>
              </summary>
              <p class="faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section catalog blueprint-bg" id="katalog">
      <div class="container">
        <div class="catalog__head">
          <div>
            <p class="mono-label reveal">Ürün kataloğu</p>
            <h2 class="display catalog__title reveal">
              Ne aradığınızı biliyorsanız,<br /><em class="display-italic metal-text">buradan ilerleyin.</em>
            </h2>
          </div>
          <p class="text-dim catalog__lede reveal">
            Karmot’un tedarik ettiği ürün grupları ve markalar. Teknik detay, seri ve model
            bilgileri ilgili katalog sayfalarında.
          </p>
        </div>

        <div class="catalog__list">
          {groups.map((group, i) => (
            <a class="catalog__item reveal" href={group.href}>
              <span class="mono-label catalog__no">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="display">{group.t}</h3>
              <span class="catalog__brands">{group.brands}</span>
              <span class="catalog__arrow" aria-hidden="true">↗</span>
            </a>
          ))}
        </div>

        <div class="brandstrip reveal">
          <span class="mono-label brandstrip__label">Tedarik ağımız:</span>
          {brands.map((brand) => (
            <a class="brandstrip__chip" href={`/markalar/${brand.id}`}>{brand.data.name}</a>
          ))}
          <a class="brandstrip__chip brandstrip__chip--all" href="/markalar">Tümünü Gör →</a>
        </div>
      </div>
    </section>

    <section class="cta" id="iletisim">
      <div class="container cta__inner">
        <div>
          <p class="mono-label reveal">Bir talebiniz mi var?</p>
          <h2 class="display cta__title">
            <span class="kin"><span class="kin-line">Teklifi</span></span>
            <span class="kin"><span class="kin-line display-italic"><em class="metal-text">Karmot</em> hazırlasın.</span></span>
          </h2>
          <p class="text-dim cta__lede reveal">
            Ürün kodunu, etiket fotoğrafını veya ihtiyacınızı gönderin. Stok, fiyat ve termin
            bilgisini birlikte netleştirelim.
          </p>
        </div>
        <div class="cta__actions reveal">
          <a class="btn cta__btn" href="mailto:info@karmot.com.tr?subject=Teklif%20Talebi%20—%20karmot.com.tr">E-posta ile Talep Aç ///</a>
          <a class="btn btn--ghost" href="/karmot-brosur.pdf" target="_blank" rel="noopener">Broşürü İnceleyin</a>
          <a class="cta__mail" href="mailto:info@karmot.com.tr">info@karmot.com.tr</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="foot">
    <div class="container foot__grid">
      <div>
        <img class="foot__logo" src={karmotLogo.src} alt="Karmot Güç Aktarım Sistemleri" width="180" height="42" />
        <p class="foot__desc text-dim">
          Endüstriyel güç aktarım ihtiyaçlarında tekliften teslimata tedarik sürecini
          yöneten tek muhatap.
        </p>
      </div>
      <nav class="foot__col" aria-label="Site haritası">
        <p class="mono-label foot__h">Karmot</p>
        <a href="#neden">Neden Karmot?</a>
        <a href="#surec">Nasıl Çalışırız?</a>
        <a href="/hakkimizda">Kurumsal</a>
        <a href="#sss">Sık Sorulanlar</a>
      </nav>
      <nav class="foot__col" aria-label="Katalog">
        <p class="mono-label foot__h">Katalog</p>
        <a href="#katalog">Ürün Grupları</a>
        <a href="/markalar">Markalar</a>
        <a href="/karmot-brosur.pdf" target="_blank" rel="noopener">Broşür (PDF)</a>
      </nav>
      <div class="foot__col">
        <p class="mono-label foot__h">İletişim</p>
        <a href="mailto:info@karmot.com.tr">info@karmot.com.tr</a>
        <a href="#iletisim">Teklif Talebi</a>
      </div>
    </div>
    <div class="container foot__bar">
      <p class="mono-label">© 2026 Karmot Güç Aktarım Sistemleri</p>
      <p class="mono-label">Tedarik bizde ///</p>
    </div>
  </footer>

  <Rpm />
</Base>

<style>
  .hero {
    min-height: 94svh;
    display: grid;
    align-items: center;
    position: relative;
    overflow: clip;
    padding-block: 8rem 4rem;
  }
  .hero__glow {
    position: absolute;
    inset: -22% -18% auto auto;
    width: 85vmin;
    aspect-ratio: 1;
    background: radial-gradient(circle, rgba(0, 105, 169, 0.22), transparent 64%);
    pointer-events: none;
  }
  .hero__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.65fr);
    gap: clamp(2.5rem, 7vw, 7rem);
    align-items: center;
  }
  .hero__copy { min-width: 0; }
  .hero__title {
    max-width: 14ch;
    font-size: clamp(2.75rem, 1rem + 3.7vw, 5.2rem);
    margin-block: 1rem 1.5rem;
  }
  .kin { display: block; overflow: clip; padding-block: 0.05em; }
  .kin-line { display: inline-block; }
  .hero__lede { max-width: 58ch; }
  .hero__cta { display: flex; flex-wrap: wrap; gap: 1rem; margin-top: 1.8rem; }
  .hero__note { margin-top: 1.4rem; color: var(--text-dim); }

  .hero__panel {
    position: relative;
    min-height: 430px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    border: 1px solid var(--line);
    background: linear-gradient(155deg, rgba(28, 45, 84, 0.72), rgba(11, 17, 34, 0.88));
    padding: 1.35rem;
    overflow: hidden;
    clip-path: polygon(0 0, calc(100% - 30px) 0, 100% 30px, 100% 100%, 0 100%);
  }
  .hero__panel::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, transparent 49.8%, rgba(86, 174, 222, 0.08) 50%, transparent 50.2%),
      linear-gradient(transparent 49.8%, rgba(86, 174, 222, 0.08) 50%, transparent 50.2%);
    background-size: 44px 44px;
    pointer-events: none;
  }
  .hero__panel-top {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }
  .hero__status {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--steel-300);
  }
  .hero__status i {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--blue-400);
    box-shadow: 0 0 14px var(--blue-400);
  }
  .hero__flow {
    position: relative;
    z-index: 2;
    display: grid;
    list-style: none;
    padding: 0;
  }
  .hero__flow li {
    display: grid;
    grid-template-columns: 2.2rem 1fr;
    gap: 0 0.8rem;
    padding-block: 1rem;
    border-top: 1px solid var(--line);
  }
  .hero__flow li:last-child { border-bottom: 1px solid var(--line); }
  .hero__flow span {
    grid-row: 1 / span 2;
    font-family: var(--font-mono);
    color: var(--blue-300);
    font-size: 0.72rem;
  }
  .hero__flow strong {
    font-family: var(--font-display);
    font-variation-settings: 'wdth' 120;
    text-transform: uppercase;
    line-height: 1.1;
  }
  .hero__flow small { color: var(--text-dim); }
  .hero__k {
    position: absolute;
    right: -0.05em;
    bottom: -0.22em;
    z-index: 1;
    font-family: var(--font-display);
    font-size: 17rem;
    font-weight: 800;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1px rgba(86, 174, 222, 0.16);
  }

  .promise-strip {
    border-block: 1px solid var(--line);
    background: var(--navy-900);
  }
  .promise-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .promise-strip__item {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 1.5rem clamp(1rem, 3vw, 2rem);
    border-right: 1px solid var(--line);
  }
  .promise-strip__item:first-child { padding-left: 0; }
  .promise-strip__item:last-child { border-right: 0; padding-right: 0; }
  .promise-strip__item h2 { font-size: 1rem; margin-bottom: 0.35rem; }
  .promise-strip__item p { color: var(--text-dim); font-size: 0.82rem; line-height: 1.5; }

  .why__intro {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 7vw, 6rem);
    align-items: end;
    margin-bottom: 2.6rem;
  }
  .why__title { font-size: var(--fs-h2); color: var(--ink); margin-top: 0.8rem; }
  .why__em { color: var(--blue-500); }
  .why__lede { color: #4c5a72; max-width: 48ch; }
  .why__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }
  .why__card {
    background: #fff;
    border: 1px solid rgba(16, 24, 47, 0.12);
    border-top: 3px solid var(--blue-500);
    padding: 1.6rem 1.5rem;
    transition: transform var(--dur-fast) var(--ease-torque), box-shadow var(--dur-fast) ease;
  }
  .why__card:hover { transform: translateY(-5px); box-shadow: 0 18px 36px rgba(16, 24, 47, 0.11); }
  .why__no { color: var(--blue-500); }
  .why__t { font-size: 1.1rem; color: var(--ink); margin-block: 0.75rem 0.55rem; }
  .why__d { color: #4c5a72; font-size: 0.92rem; }

  .process {
    background: var(--paper-2);
    border-block: 1px solid rgba(16, 24, 47, 0.1);
  }
  .process__title { font-size: var(--fs-h2); color: var(--ink); margin-block: 0.8rem 2.3rem; }
  .process__title em { color: var(--blue-500); }
  .process__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.2rem, 4vw, 3rem);
  }
  .process__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.1rem;
    align-items: start;
    border-top: 1px solid rgba(16, 24, 47, 0.22);
    padding-top: 1.2rem;
  }
  .process__n { font-size: 2.2rem; color: transparent; -webkit-text-stroke: 1.5px var(--blue-500); }
  .process__t { font-size: 1.08rem; color: var(--ink); margin-bottom: 0.45rem; }
  .process__d { color: #4c5a72; font-size: 0.93rem; max-width: 34ch; }

  .faq__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
  .faq__head,
  .faq__list { min-width: 0; }
  .faq__title { font-size: var(--fs-h2); color: var(--ink); margin-block: 0.8rem 1rem; }
  .faq__em { color: var(--blue-500); }
  .faq__lede { color: #4c5a72; max-width: 38ch; margin-bottom: 1.6rem; }
  .faq__list { display: grid; }
  .faq__item { border-top: 1px solid rgba(16, 24, 47, 0.16); }
  .faq__item:last-child { border-bottom: 1px solid rgba(16, 24, 47, 0.16); }
  .faq__q {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.4rem;
    padding: 1.1rem 0.2rem;
    cursor: pointer;
    list-style: none;
    font-weight: 700;
    color: var(--ink);
    font-size: 1rem;
  }
  .faq__q > span { min-width: 0; overflow-wrap: anywhere; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__plus { position: relative; flex: none; width: 14px; height: 14px; }
  .faq__plus::before,
  .faq__plus::after {
    content: '';
    position: absolute;
    inset: 0;
    margin: auto;
    background: var(--blue-500);
    transition: transform 0.3s var(--ease-torque);
  }
  .faq__plus::before { width: 14px; height: 2px; }
  .faq__plus::after { width: 2px; height: 14px; }
  .faq__item[open] .faq__plus::after { transform: rotate(90deg); }
  .faq__a { color: #4c5a72; font-size: 0.95rem; max-width: 62ch; padding: 0 2.4rem 1.25rem 0.2rem; }

  .catalog {
    background:
      radial-gradient(100vmin 70vmin at 85% 12%, rgba(0, 105, 169, 0.12), transparent 60%),
      var(--navy-950);
  }
  .catalog__head {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 7vw, 6rem);
    align-items: end;
    margin-bottom: 2.4rem;
  }
  .catalog__title { font-size: var(--fs-h2); margin-top: 0.8rem; }
