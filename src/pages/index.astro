---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import IndustrialIcon from '../components/IndustrialIcon.astro';
import karmotLogo from '../assets/karmot-logo.svg';
import { kategoriler, toplamAltKategori } from '../data/urunler';

const urunImgs = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/urunler/**/*.{png,jpg,jpeg}',
  { eager: true }
);
const urunImg = (img: string) => (img ? urunImgs[`../assets/urunler/${img}`]?.default : undefined);

/* Hero slider — mal sahibinin gönderdiği sloganlar, harfiyen */
const slides = [
  {
    t: 'Güç Aktarımında Yüksek Verimli Çözümler',
    d: 'Redüktör, elektrik motoru, pompa, fan ve elektromanyetik frende doğru ürüne en kısa yoldan ulaşın.',
    img: 'reduktorler/helisel-disli-reduktorler.png',
  },
  {
    t: 'Verim Odaklı Endüstriyel Çözümler',
    d: 'İhtiyacınıza göre seçenekleri karşılaştırır; stok, fiyat ve termini tek teklifte netleştiririz.',
    img: 'motorlar/alcak-gerilim-motorlari.png',
  },
  {
    t: 'Güçlü Markalar, Güvenilir Çözümler',
    d: 'Beş ürün grubunda güvenilir tedarik: tek talep, tek muhatap, uçtan uca takip.',
    img: 'pompalar/uctan-emisli-pompalar.png',
  },
  {
    t: 'Verim Odaklı Çözümler',
    d: 'Enerji verimliliği yüksek seriler ve uygulamanıza uygun seçimle işletme maliyetinizi düşürün.',
    img: 'fanlar/kanal-fanlari.png',
  },
];

const promises = [
  { icon: 'contact', t: 'Tek muhatap', d: 'Talep, teklif ve sipariş aynı Karmot akışında ilerler.' },
  { icon: 'options', t: 'Açık seçenekler', d: 'Stok, termin ve uygun alternatifler net biçimde önünüzdedir.' },
  { icon: 'tracking', t: 'Süreç takibi', d: 'Onaydan teslimata kadar işi Karmot takip eder.' },
] as const;

const why = [
  {
    t: 'Talebi doğru anlarız',
    d: 'Kodunuz hazırsa hızlı ilerleriz; değilse etiket veya uygulama bilgisini birlikte netleştiririz.',
  },
  {
    t: 'Seçenekleri açık sunarız',
    d: 'Stok, termin ve uygun alternatifleri artılarıyla birlikte tek tabloda önünüze koyarız.',
  },
  {
    t: 'Süreci sahipleniriz',
    d: 'Tekliften sevkiyata kadar farklı kişiler arasında dolaşmadan tek bir Karmot muhatabıyla ilerlersiniz.',
  },
  {
    t: 'Teslimattan sonra da buradayız',
    d: 'Ürün sahaya ulaştığında teknik veya servis ihtiyacınızı doğru kanala ulaştırırız.',
  },
];

const steps = [
  { n: '01', t: 'Talebi paylaşın', d: 'Ürün kodunu, etiket fotoğrafını veya ihtiyacınızı gönderin.' },
  { n: '02', t: 'Net teklif alın', d: 'Uygun seçenekleri stok, fiyat ve termin bilgisiyle birlikte sunalım.' },
  { n: '03', t: 'Karmot takip etsin', d: 'Onaydan sevkiyata kadar süreci biz izleyelim; siz işinize devam edin.' },
];

const faq = [
  {
    q: 'Ürün kodunu biliyorum; nasıl hızlı teklif alırım?',
    a: 'Kod, adet ve teslimat bilgisini e-postayla paylaşın. Varsa etiket fotoğrafını ekleyin; Karmot stok ve termin seçeneklerini tek teklifte netleştirsin.',
  },
  {
    q: 'Koddan emin değilsem yardımcı olur musunuz?',
    a: 'Evet. Etiket fotoğrafı, mevcut ürün bilgisi veya uygulama detayları üzerinden ihtiyacı birlikte netleştiririz.',
  },
  {
    q: 'Stokta yoksa ne olur?',
    a: 'Beklenen tedarik süresini ve varsa teknik olarak uygun alternatifleri açıkça paylaşırız; seçimi sizin onayınızla ilerletiriz.',
  },
  {
    q: 'Farklı ürün gruplarını tek siparişte toplayabilir miyim?',
    a: 'Redüktör, motor, pompa, fan ve fren ihtiyaçlarını tek talepte birleştirebilirsiniz: tek teklif, tek sipariş, tek muhatap.',
  },
  {
    q: 'Teslimattan sonra kime ulaşırım?',
    a: 'Sipariş sırasında görüştüğünüz Karmot muhatabı teknik veya servis ihtiyacınızı doğru kanala yönlendirir.',
  },
];

/* Ürün grubu kartları için kapak görselleri */
const kapak: Record<string, string> = {
  reduktorler: 'reduktorler/helisel-disli-reduktorler.png',
  motorlar: 'motorlar/alcak-gerilim-motorlari.png',
  pompalar: 'pompalar/uctan-emisli-pompalar.png',
  fanlar: 'fanlar/kanal-fanlari.png',
  fren: 'fren/elektromanyetik-frenler.png',
};
---

<Base
  title="Karmot | Endüstriyel Güç Aktarım Sistemleri Tedarikçisi"
  description="Karmot; redüktör, AC elektrik motoru, pompa, fan ve elektromanyetik fren tedarikinde açık stok ve termin bilgisi, uygun alternatifler ve tek muhatapla süreci kolaylaştırır."
>
  <Nav />

  <main>
    <!-- HERO SLIDER: müşteri sloganları -->
    <section class="slider" id="hero" data-slider aria-label="Karmot tanıtım">
      <div class="container slider__frame">
        {slides.map((s, i) => {
          const img = urunImg(s.img);
          return (
            <div class:list={['slide', i === 0 && 'is-active']}>
              <div class="slide__copy">
                <p class="mono-label">Karmot Güç Aktarım Sistemleri</p>
                {i === 0
                  ? <h1 class="display slide__title">{s.t}</h1>
                  : <p class="display slide__title" role="heading" aria-level="2">{s.t}</p>}
                <p class="slide__lede">{s.d}</p>
                <div class="slide__cta">
                  <a class="btn" href="#iletisim">Teklif İsteyin</a>
                  <a class="btn btn--ghost slide__ghostbtn" href="/urunler">Ürünlerimiz</a>
                </div>
              </div>
              <div class="slide__fig" aria-hidden="true">
                {img && <Image src={img} alt="" height={330} quality={84} loading={i === 0 ? 'eager' : 'lazy'} />}
              </div>
            </div>
          );
        })}
        <div class="slider__dots" role="tablist" aria-label="Slayt seçimi">
          {slides.map((_, i) => (
            <button
              class:list={['slider__dot', i === 0 && 'is-active']}
              data-dot={i}
              type="button"
              aria-label={`Slayt ${i + 1}`}
            ></button>
          ))}
        </div>
      </div>
    </section>

    <!-- KARMOT STANDARDI -->
    <section class="promise-strip" id="standart" aria-label="Karmot tedarik yaklaşımı">
      <div class="container">
        <div class="promise-strip__grid">
          {promises.map((promise, i) => (
            <article class="promise-strip__item reveal">
              <span class="promise-strip__icon" aria-hidden="true">
                <IndustrialIcon name={promise.icon} />
              </span>
              <span class="mono-label promise-strip__no">0{i + 1}</span>
              <div>
                <h3 class="display">{promise.t}</h3>
                <p>{promise.d}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ÜRÜN GRUPLARIMIZ -->
    <section class="section groups" id="katalog">
      <div class="container">
        <div class="groups__head">
          <div>
            <p class="mono-label reveal">Ürün Gruplarımız</p>
            <h2 class="display groups__title reveal">Beş grupta {toplamAltKategori} alt kategori</h2>
          </div>
          <p class="groups__lede reveal">
            Redüktörden elektromanyetik frene, aradığınız ürün grubunu seçin;
            alt kategorilere ve teknik detaylara ilerleyin.
          </p>
        </div>
        <div class="groups__grid">
          {kategoriler.map((grup) => {
            const img = urunImg(kapak[grup.slug] ?? '');
            return (
              <a class="gcard reveal" href={`/urunler/${grup.slug}`}>
                <span class="gcard__fig" aria-hidden="true">
                  {img
                    ? <Image src={img} alt="" height={180} quality={82} />
                    : <IndustrialIcon name={grup.icon} />}
                </span>
                <span class="gcard__body">
                  <strong class="display gcard__name">{grup.name}</strong>
                  <span class="gcard__meta">{grup.items.length} alt kategori</span>
                  <span class="gcard__link">İncele →</span>
                </span>
              </a>
            );
          })}
        </div>
      </div>
    </section>

    <!-- NEDEN KARMOT -->
    <section class="section why" id="neden">
      <div class="container">
        <div class="why__intro">
          <div>
            <p class="mono-label reveal">Karmot neyi farklı yapar?</p>
            <h2 class="display why__title reveal">
              Ürünü değil, <em class="why__em">tedarik sürecini</em> çözeriz.
            </h2>
          </div>
          <p class="why__lede reveal">
            Müşterimiz ürünü çoğu zaman zaten bilir. Karmot’un işi; doğru kodu doğrulamak,
            seçenekleri karşılaştırmak, stok ve termini netleştirmek, siparişten teslimata
            kadar süreci takip etmektir.
          </p>
        </div>
        <div class="why__grid">
          {why.map((item, i) => (
            <article class="why__card reveal">
              <span class="mono-label why__no">{String(i + 1).padStart(2, '0')}</span>
              <h3 class="display why__t">{item.t}</h3>
              <p class="why__d">{item.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SÜREÇ -->
    <section class="section process" id="surec">
      <div class="container">
        <p class="mono-label reveal">Nasıl çalışırız?</p>
        <h2 class="display process__title reveal">Talebinizden teslimata, <em>tek akış.</em></h2>
        <div class="process__grid">
          {steps.map((step) => (
            <article class="process__step reveal">
              <span class="display process__n">{step.n}</span>
              <div>
                <h3 class="display process__t">{step.t}</h3>
                <p class="process__d">{step.d}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- SSS -->
    <section class="section faq" id="sss">
      <div class="container faq__grid">
        <div class="faq__head">
          <p class="mono-label reveal">Satın almadan önce</p>
          <h2 class="display faq__title reveal">Sık sorulanlar, <em class="faq__em">net cevaplar.</em></h2>
          <p class="faq__lede reveal">
            Aradığınız cevap burada yoksa ürün kodunu veya etiket fotoğrafını gönderin;
            Karmot sizin için netleştirsin.
          </p>
          <a class="btn reveal" href="#iletisim">Talebinizi İletin</a>
        </div>
        <div class="faq__list">
          {faq.map((item) => (
            <details class="faq__item reveal">
              <summary class="faq__q">
                <span>{item.q}</span>
                <i class="faq__plus" aria-hidden="true"></i>
              </summary>
              <p class="faq__a">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- TEKLİF -->
    <section class="cta dark-surface" id="iletisim">
      <div class="container cta__inner">
        <div>
          <p class="mono-label reveal">Bir talebiniz mi var?</p>
          <h2 class="display cta__title">Teklifi Karmot hazırlasın.</h2>
          <p class="text-dim cta__lede reveal">
            Ürün kodunu, etiket fotoğrafını veya ihtiyacınızı gönderin. Stok, fiyat ve termin
            bilgisini birlikte netleştirelim.
          </p>
        </div>
        <div class="cta__actions reveal">
          <a class="btn cta__btn" href="mailto:info@karmot.com.tr?subject=Teklif%20Talebi%20—%20karmot.com.tr">E-posta ile Talep Aç</a>
          <a class="btn btn--ghost" href="/karmot-brosur.pdf" target="_blank" rel="noopener">Broşürü İnceleyin</a>
          <a class="cta__mail" href="mailto:info@karmot.com.tr">info@karmot.com.tr</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="foot dark-surface">
    <div class="container foot__grid">
      <div>
        <img class="foot__logo" src={karmotLogo.src} alt="Karmot Güç Aktarım Sistemleri" width="180" height="42" />
        <p class="foot__desc text-dim">
          Endüstriyel güç aktarım ihtiyaçlarında tekliften teslimata tedarik sürecini
          yöneten tek muhatap.
        </p>
      </div>
      <nav class="foot__col" aria-label="Site haritası">
        <p class="mono-label foot__h">Karmot</p>
        <a href="/hakkimizda">Kurumsal</a>
        <a href="#neden">Neden Karmot?</a>
        <a href="#surec">Nasıl Çalışırız?</a>
        <a href="#sss">Sık Sorulanlar</a>
      </nav>
      <nav class="foot__col" aria-label="Ürünler">
        <p class="mono-label foot__h">Ürünler</p>
        {kategoriler.map((g) => <a href={`/urunler/${g.slug}`}>{g.name}</a>)}
      </nav>
      <div class="foot__col">
        <p class="mono-label foot__h">İletişim</p>
        <a href="mailto:info@karmot.com.tr">info@karmot.com.tr</a>
        <a href="#iletisim">Teklif Talebi</a>
        <a href="/karmot-brosur.pdf" target="_blank" rel="noopener">Broşür (PDF)</a>
      </div>
    </div>
    <div class="container foot__bar">
      <p>© 2026 Karmot Güç Aktarım Sistemleri</p>
    </div>
  </footer>
</Base>

<style>
  /* ---------- HERO SLIDER ---------- */
  .slider {
    margin-top: 64px; /* sabit beyaz nav yüksekliği */
    background:
      radial-gradient(90vmin 70vmin at 85% 15%, rgba(0, 105, 169, 0.35), transparent 62%),
      linear-gradient(140deg, var(--navy-850), var(--navy-950) 70%);
    color: var(--text);
  }
  .slider__frame {
    position: relative;
    min-height: clamp(430px, 62vh, 560px);
  }
  .slide {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: center;
    padding-block: 3rem;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.7s ease, visibility 0s 0.7s;
  }
  .slide.is-active {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.7s ease;
  }
  .slide__title {
    color: #fff;
    font-size: clamp(1.9rem, 1rem + 2.9vw, 3.4rem);
    margin-block: 0.9rem 1rem;
    max-width: 18ch;
  }
  .slide__lede {
    color: var(--text-dim);
    max-width: 46ch;
    margin-bottom: 1.6rem;
  }
  .slide__cta { display: flex; flex-wrap: wrap; gap: 0.9rem; }
  .slide__ghostbtn {
    color: #fff;
    box-shadow: inset 0 0 0 1.5px rgba(255, 255, 255, 0.38);
  }
  .slide__ghostbtn:hover {
    background: rgba(255, 255, 255, 0.1);
    box-shadow: inset 0 0 0 1.5px var(--blue-400);
  }
  .slide__fig {
    justify-self: end;
    width: min(100%, 420px);
    background: #fff;
    border-radius: var(--r-lg);
    padding: 1.6rem;
    box-shadow: 0 30px 70px rgba(2, 7, 18, 0.35);
  }
  .slide__fig :global(img) {
    width: 100%;
    height: clamp(200px, 30vh, 300px);
    object-fit: contain;
  }
  .slider__dots {
    position: absolute;
    left: 0;
    bottom: 1.4rem;
    display: flex;
    gap: 10px;
    z-index: 3;
  }
  .slider__dot {
    width: 34px;
    height: 5px;
    border-radius: 999px;
    background: rgba(159, 176, 201, 0.35);
    transition: background 0.3s ease;
  }
  .slider__dot.is-active { background: var(--blue-400); }

  /* ---------- KARMOT STANDARDI ---------- */
  .promise-strip {
    background: #fff;
    border-bottom: 1px solid rgba(27, 42, 74, 0.08);
    padding-block: clamp(1.8rem, 4vw, 2.6rem);
  }
  .promise-strip__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 3vw, 2.5rem);
  }
  .promise-strip__item {
    display: grid;
    grid-template-columns: 3.2rem auto 1fr;
    gap: 0.85rem;
    align-items: center;
  }
  .promise-strip__icon {
    display: grid;
    place-items: center;
    width: 3.2rem;
    height: 3.2rem;
    color: var(--blue-500);
    background: rgba(0, 105, 169, 0.08);
    border-radius: var(--r-sm);
  }
  .promise-strip__icon :global(svg) { width: 2rem; height: 2rem; }
  .promise-strip__no { color: rgba(27, 42, 74, 0.35); }
  .promise-strip__item h3 { font-size: 0.98rem; color: var(--ink); margin-bottom: 0.2rem; }
  .promise-strip__item p { color: var(--ink-dim); font-size: 0.84rem; line-height: 1.45; }

  /* ---------- ÜRÜN GRUPLARI ---------- */
  .groups { background: var(--paper); }
  .groups__head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.9fr);
    gap: clamp(1.5rem, 5vw, 5rem);
    align-items: end;
    margin-bottom: 2.2rem;
  }
  .groups__title { font-size: var(--fs-h2); color: var(--ink); margin-top: 0.7rem; }
  .groups__lede { color: var(--ink-dim); max-width: 44ch; }
  .groups__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
    gap: 14px;
  }
  .gcard {
    display: grid;
    background: #fff;
    border: 1px solid rgba(27, 42, 74, 0.1);
    border-radius: var(--r-md);
    overflow: hidden;
    transition: transform 0.28s var(--ease-torque), box-shadow 0.28s ease, border-color 0.2s ease;
  }
  .gcard:hover {
    transform: translateY(-6px);
    border-color: rgba(0, 105, 169, 0.35);
    box-shadow: 0 20px 40px rgba(27, 42, 74, 0.12);
  }
  .gcard__fig {
    display: grid;
    place-items: center;
    height: 170px;
    padding: 1rem;
    background: linear-gradient(180deg, #ffffff, #f2f4f6);
    border-bottom: 1px solid rgba(27, 42, 74, 0.07);
    color: var(--blue-500);
  }
  .gcard__fig :global(img) { max-height: 100%; width: auto; max-width: 100%; object-fit: contain; }
  .gcard__fig :global(svg) { width: 84px; height: 84px; stroke-width: 1.6; }
  .gcard__body { display: grid; gap: 0.3rem; padding: 1.1rem 1.2rem 1.3rem; }
  .gcard__name { color: var(--ink); font-size: 1.08rem; line-height: 1.25; }
  .gcard__meta { color: var(--ink-dim); font-size: 0.82rem; }
  .gcard__link { color: var(--blue-500); font-weight: 700; font-size: 0.86rem; margin-top: 0.4rem; }

  /* ---------- NEDEN ---------- */
  .why { background: #fff; border-block: 1px solid rgba(27, 42, 74, 0.07); }
  .why__intro {
    display: grid;
    grid-template-columns: minmax(0, 1.1fr) minmax(0, 0.9fr);
    gap: clamp(2rem, 7vw, 6rem);
    align-items: end;
    margin-bottom: 2.4rem;
  }
  .why__title { font-size: var(--fs-h2); color: var(--ink); margin-top: 0.8rem; }
  .why__em { color: var(--blue-500); font-style: normal; }
  .why__lede { color: var(--ink-dim); max-width: 48ch; }
  .why__grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 12px;
  }
  .why__card {
    background: var(--paper);
    border: 1px solid rgba(27, 42, 74, 0.1);
    border-radius: var(--r-md);
    padding: 1.5rem 1.4rem;
    transition: transform var(--dur-fast) var(--ease-torque), box-shadow var(--dur-fast) ease;
  }
  .why__card:hover { transform: translateY(-5px); box-shadow: 0 16px 32px rgba(27, 42, 74, 0.1); }
  .why__no { color: var(--blue-500); }
  .why__t { font-size: 1.05rem; color: var(--ink); margin-block: 0.7rem 0.5rem; }
  .why__d { color: var(--ink-dim); font-size: 0.92rem; }

  /* ---------- SÜREÇ ---------- */
  .process { background: var(--paper-2); }
  .process__title { font-size: var(--fs-h2); color: var(--ink); margin-block: 0.8rem 2.2rem; }
  .process__title em { color: var(--blue-500); font-style: normal; }
  .process__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1.2rem, 4vw, 3rem);
  }
  .process__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.1rem;
    align-items: start;
    border-top: 2px solid rgba(27, 42, 74, 0.16);
    padding-top: 1.2rem;
  }
  .process__n { font-size: 2.1rem; color: transparent; -webkit-text-stroke: 1.5px var(--blue-500); }
  .process__t { font-size: 1.05rem; color: var(--ink); margin-bottom: 0.4rem; }
  .process__d { color: var(--ink-dim); font-size: 0.93rem; max-width: 34ch; }

  /* ---------- SSS ---------- */
  .faq { background: #fff; border-top: 1px solid rgba(27, 42, 74, 0.07); }
  .faq__grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: clamp(2rem, 6vw, 5rem);
    align-items: start;
  }
