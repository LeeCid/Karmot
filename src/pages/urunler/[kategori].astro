---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import { kategoriler } from '../../data/urunler';
import type { UrunKategori } from '../../data/urunler';

export function getStaticPaths() {
  return kategoriler.map((k) => ({ params: { kategori: k.slug }, props: { aktif: k } }));
}

interface Props {
  aktif: UrunKategori;
}
const { aktif } = Astro.props;

const urunImgs = import.meta.glob<{ default: ImageMetadata }>(
  '../../assets/urunler/**/*.{png,jpg,jpeg}',
  { eager: true }
);
const urunImg = (img: string) => (img ? urunImgs[`../../assets/urunler/${img}`]?.default : undefined);
---

<Base
  title={`${aktif.name} | Karmot Ürünleri`}
  description={`Karmot ${aktif.name.toLowerCase()} tedariki: ${aktif.items.map((i) => i.name).slice(0, 5).join(', ')}${aktif.items.length > 5 ? ' ve daha fazlası' : ''}. Teklif için ürün kodunuzu veya uygulamanızı iletin.`}
>
  <Nav />

  <main class="cat">
    <header class="cat__head">
      <div class="container">
        <p class="cat__crumb"><a href="/">Ana Sayfa</a> / <a href="/urunler">Ürünlerimiz</a> / <span>{aktif.name}</span></p>
        <h1 class="display cat__title">{aktif.name}</h1>
        <p class="cat__lede">{aktif.blurb} — {aktif.items.length} alt kategori.</p>
      </div>
    </header>

    <div class="container cat__layout">
      <!-- SOL MENÜ (dgmr düzeni) -->
      <aside class="side" aria-label="Ürün grupları">
        {kategoriler.map((k) => (
          <div class:list={['side__group', k.slug === aktif.slug && 'is-active']}>
            <a class="side__cat" href={`/urunler/${k.slug}`}>
              {k.slug === aktif.slug && <span class="side__arrow" aria-hidden="true">→</span>}
              {k.name}
            </a>
            {k.slug === aktif.slug && (
              <ul class="side__items">
                {k.items.map((item) => (
                  <li><a href={`#${item.slug}`}>{item.name}</a></li>
                ))}
              </ul>
            )}
          </div>
        ))}
        <a class="btn side__cta" href="/#iletisim">Teklif Al</a>
      </aside>

      <!-- İÇERİK -->
      <div class="cat__content">
        {aktif.items.map((item) => {
          const img = urunImg(item.img);
          return (
            <article class="prod" id={item.slug}>
              <div class="prod__fig" aria-hidden="true">
                {img
                  ? <Image src={img} alt={item.name} height={260} quality={84} />
                  : <span class="prod__nofig">Görsel hazırlanıyor</span>}
              </div>
              <div class="prod__body">
                <h2 class="display prod__name">{item.name}</h2>
                <p class="prod__desc">{item.desc}</p>
                {aktif.features && (
                  <div class="prod__features">
                    <h3 class="prod__ft">Ürün Özellikleri</h3>
                    <ul>
                      {aktif.features.map((f) => <li>{f}</li>)}
                    </ul>
                  </div>
                )}
                <a class="prod__link" href="/#iletisim">Bu ürün için teklif isteyin →</a>
              </div>
            </article>
          );
        })}
      </div>
    </div>
  </main>

  <footer class="foot dark-surface">
    <div class="container foot__bar">
      <p>© 2026 Karmot Güç Aktarım Sistemleri · <a href="/">Ana Sayfa</a> · <a href="/urunler">Ürünlerimiz</a></p>
    </div>
  </footer>
</Base>

<style>
  .cat { margin-top: 64px; }
  .cat__head {
    background: linear-gradient(140deg, var(--navy-850), var(--navy-950) 75%);
    color: #fff;
    padding: clamp(2.2rem, 5vw, 3.4rem) 0;
  }
  .cat__crumb { font-size: 0.82rem; color: var(--text-dim); margin-bottom: 0.7rem; }
  .cat__crumb a { color: var(--blue-300); }
  .cat__crumb span { color: #fff; }
  .cat__title { font-size: clamp(1.9rem, 4vw, 3rem); }
  .cat__lede { color: var(--text-dim); margin-top: 0.5rem; }

  .cat__layout {
    display: grid;
    grid-template-columns: 280px minmax(0, 1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    padding-block: clamp(2rem, 5vw, 3.2rem) clamp(3rem, 7vw, 5rem);
    align-items: start;
  }

  /* SOL MENÜ */
  .side {
    position: sticky;
    top: 84px;
    display: grid;
    gap: 10px;
  }
  .side__cat {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.95rem 1.1rem;
    background: #fff;
    border: 1px solid rgba(27, 42, 74, 0.12);
    border-radius: var(--r-sm);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--ink);
    transition: border-color 0.2s ease, color 0.2s ease, transform 0.2s var(--ease-torque);
  }
  .side__cat:hover { border-color: var(--blue-400); color: var(--blue-500); transform: translateX(2px); }
  .side__group.is-active .side__cat {
    background: var(--blue-500);
    border-color: var(--blue-500);
    color: #fff;
  }
  .side__arrow { font-weight: 800; }
  .side__items {
    list-style: none;
    margin: 8px 0 4px;
    padding: 0;
    display: grid;
    gap: 6px;
  }
  .side__items a {
    display: block;
    padding: 0.62rem 0.95rem;
    background: #fff;
    border: 1px solid rgba(27, 42, 74, 0.1);
    border-radius: var(--r-sm);
    font-size: 0.85rem;
    color: var(--ink-dim);
    transition: border-color 0.2s ease, color 0.2s ease;
  }
  .side__items a:hover { border-color: var(--blue-400); color: var(--blue-500); }
  .side__cta { justify-content: center; margin-top: 0.4rem; }

  /* İÇERİK */
  .cat__content { display: grid; gap: 16px; }
  .prod {
    display: grid;
    grid-template-columns: minmax(220px, 340px) minmax(0, 1fr);
    gap: clamp(1.2rem, 3vw, 2.2rem);
    background: #fff;
    border: 1px solid rgba(27, 42, 74, 0.1);
    border-radius: var(--r-md);
    padding: clamp(1.2rem, 3vw, 1.8rem);
    scroll-margin-top: 90px;
  }
  .prod__fig {
    display: grid;
    place-items: center;
    background: linear-gradient(180deg, #ffffff, #f2f4f6);
    border: 1px solid rgba(27, 42, 74, 0.07);
    border-radius: var(--r-sm);
    min-height: 220px;
    padding: 1rem;
  }
  .prod__fig :global(img) { max-width: 100%; height: auto; max-height: 240px; object-fit: contain; }
  .prod__nofig { color: var(--ink-dim); font-size: 0.85rem; }
  .prod__name { font-size: 1.3rem; color: var(--ink); margin-bottom: 0.6rem; }
  .prod__desc { color: var(--ink-dim); max-width: 62ch; }
  .prod__features { margin-top: 1.1rem; border-top: 1px solid rgba(27, 42, 74, 0.1); padding-top: 1rem; }
  .prod__ft { font-weight: 800; color: var(--ink); font-size: 0.95rem; margin-bottom: 0.6rem; }
  .prod__features ul { list-style: none; padding: 0; display: grid; gap: 0.4rem; }
  .prod__features li {
    position: relative;
    padding-left: 1.1rem;
    color: var(--ink-dim);
    font-size: 0.88rem;
  }
  .prod__features li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.52em;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--blue-500);
  }
  .prod__link {
    display: inline-block;
    margin-top: 1.1rem;
    color: var(--blue-500);
    font-weight: 700;
    font-size: 0.9rem;
  }

  .foot { padding-top: 0.5rem; }
  .foot__bar {
    border-top: 1px solid var(--line);
    padding-block: 1.3rem 5.5rem;
    color: var(--text-dim);
    font-size: 0.85rem;
  }
  .foot__bar a { color: var(--blue-300); }

  @media (max-width: 860px) {
    .cat__layout { grid-template-columns: minmax(0, 1fr); }
    .side { position: static; }
    .side__items { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); }
    .prod { grid-template-columns: minmax(0, 1fr); }
    .prod__fig { min-height: 180px; }
  }
</style>

<script>
  import '../../scripts/subpage';
</script>
