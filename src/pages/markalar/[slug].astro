---
import { getCollection, type CollectionEntry } from 'astro:content';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Rpm from '../../components/Rpm.astro';

export async function getStaticPaths() {
  const brands = await getCollection('brands');
  return brands.map((b) => ({ params: { slug: b.id }, props: { brand: b } }));
}

interface Props {
  brand: CollectionEntry<'brands'>;
}
const { brand } = Astro.props;
const d = brand.data;

const imgs = import.meta.glob<{ default: ImageMetadata }>('../../assets/products/*.png', { eager: true });
const lineup = imgs[`../../assets/products/${brand.id}-lineup.png`]?.default;

const all = (await getCollection('brands')).sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((b) => b.id === brand.id);
const next = all[(idx + 1) % all.length];
---

<Base
  title={`${d.name} — Karmot Güç Aktarım Sistemleri`}
  description={`${d.name}: ${d.tagline}. ${d.description.slice(0, 140)}`}
>
  <Nav />

  <main class="brand blueprint-bg">
    <div class="container brand__head">
      <p class="mono-label brand__crumb">
        <a href="/#zincir">← Güç Zinciri</a> · Görev {d.roleNo} — {d.role} · Halka {String(d.order).padStart(2, '0')} / 07
      </p>
      <h1 class="display brand__name">
        <span class="kin"><span class="kin-line">{d.name}</span></span>
      </h1>
      <p class="display-italic brand__tag">
        <span class="kin"><span class="kin-line">{d.tagline}</span></span>
      </p>
    </div>

    {lineup && (
      <div class="container">
        <figure class="film-frame reveal">
          <Image src={lineup} alt={`${d.name} ürün ailesi`} height={280} quality={85} />
        </figure>
      </div>
    )}

    <div class="container brand__grid">
      <div>
        <p class="mono-label reveal">Marka Profili</p>
        <p class="brand__desc reveal">{d.description}</p>
        {d.website && (
          <a class="mono-label brand__site reveal" href={d.website} target="_blank" rel="noopener">
            Üretici sitesi ↗
          </a>
        )}
        <div class="brand__specs">
          {d.specs.map((s) => (
            <div class="spec-row reveal">
              <span class="spec-row__k">{s.k}</span>
              <span class="spec-row__v">{s.v}</span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <p class="mono-label reveal">Ürün Grupları</p>
        <ul class="brand__groups">
          {d.productGroups.map((g) => (
            <li class="reveal">
              <span class="slashes" aria-hidden="true"><i></i><i></i><i></i></span>
              {g}
            </li>
          ))}
        </ul>
        <p class="mono-label brand__note reveal">
          [Not] Detaylı ürün listesi ve stok bilgisi için teklif isteyin — aynı gün dönüş hedefliyoruz.
        </p>
      </div>
    </div>

    <div class="container brand__cta">
      <a class="btn" href={`/#iletisim`}>Bu Markadan Teklif Alın ///</a>
      <a class="btn btn--ghost" href={`/markalar/${next.id}`}>Sıradaki Halka: {next.data.name} →</a>
    </div>
  </main>

  <footer class="brand__foot">
    <p class="mono-label">© 2026 Karmot Güç Aktarım Sistemleri · <a href="/">Ana Sayfa</a> · <a href="/markalar">Tüm Markalar</a></p>
  </footer>

  <Rpm />
</Base>

<style>
  .brand {
    padding-top: 8.5rem;
    min-height: 100svh;
  }
  .brand__crumb a { color: var(--blue-300); }
  .brand__crumb a:hover { color: #fff; }
  .brand__name {
    font-size: var(--fs-hero);
    margin-block: 0.6rem 0.2rem;
  }
  .brand__tag {
    font-family: var(--font-display);
    font-variation-settings: 'wdth' 112;
    font-weight: 600;
    font-size: var(--fs-h3);
    color: var(--steel-300);
    margin-bottom: 2.2rem;
  }
  .kin { display: block; overflow: clip; padding-block: 0.05em; }
  .kin-line { display: inline-block; }

  .film-frame {
    background: #fff;
    padding: 1.7rem 1.3rem;
    position: relative;
    clip-path: polygon(0 0, calc(100% - var(--cut)) 0, 100% var(--cut), 100% 100%, var(--cut) 100%, 0 calc(100% - var(--cut)));
  }
  .film-frame::before,
  .film-frame::after {
    content: '';
    position: absolute;
    left: 0;
    right: 0;
    height: 10px;
    background-image: repeating-linear-gradient(90deg, var(--navy-950) 0 14px, transparent 14px 30px);
  }
  .film-frame::before { top: 6px; }
  .film-frame::after { bottom: 6px; }
  .film-frame :global(img) {
    width: 100%;
    height: clamp(130px, 24vh, 230px);
    object-fit: contain;
  }

  .brand__grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: clamp(2rem, 6vw, 5rem);
    padding-block: clamp(2.5rem, 6vh, 4.5rem);
  }
  .brand__desc {
    margin-block: 0.8rem 1.2rem;
    color: var(--text-dim);
    max-width: 56ch;
  }
  .brand__site { color: var(--blue-300); display: inline-block; margin-bottom: 1.8rem; }
  .brand__site:hover { color: #fff; }
  .brand__specs { border-top: 1px solid var(--line); }
  .spec-row {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    padding: 0.7rem 0.2rem;
    border-bottom: 1px dashed var(--line);
    font-family: var(--font-mono);
    font-size: 0.8rem;
  }
  .spec-row__k { color: var(--blue-300); letter-spacing: 0.12em; }
  .spec-row__v { color: var(--steel-300); text-align: right; }

  .brand__groups {
    list-style: none;
    padding: 0;
    margin: 1rem 0 1.6rem;
    display: grid;
    gap: 0.85rem;
  }
  .brand__groups li {
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
    padding-bottom: 0.85rem;
    border-bottom: 1px solid var(--line);
  }
  .brand__groups .slashes { font-size: 0.55rem; flex: none; }
  .brand__note { color: var(--text-dim); }

  .brand__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    padding-bottom: clamp(3rem, 8vh, 6rem);
  }
  .brand__foot {
    border-top: 1px solid var(--line);
    padding: 1.6rem var(--gutter) 2.2rem;
  }
  .brand__foot a { color: var(--blue-300); }

  @media (max-width: 800px) {
    .brand__grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  import '../../scripts/subpage';
</script>
